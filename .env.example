# Variáveis usadas pelo docker-compose da raiz (front + back + banco).
# Copie para .env: cp .env.example .env
#
# Os segredos do backend/banco (POSTGRES_*, DB_URL, JWT_*) ficam em
# back-end/BACK-END-API-WEB-LOJA/sistema-loja/.env (carregado via env_file).

# Portas expostas no host
POSTGRES_PORT=5432
APP_PORT=8080
FRONTEND_PORT=3000

# Frontend (Next.js / NextAuth)
# URL da API acessível pelo NAVEGADOR (precisa bater no host, não no nome do container).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
# Gere um segredo forte: openssl rand -base64 32
NEXTAUTH_SECRET=troque-este-segredo-em-producao
